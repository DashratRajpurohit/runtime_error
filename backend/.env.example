# LLM Provider configuration: openai | gemini | ollama
LLM_PROVIDER=ollama

# Ollama settings (for local Llama model)
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3

# API Keys (if using hosted providers)
OPENAI_API_KEY=your_openai_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
# NVIDIA API key stored separately in secrets.env (var name: NAK)

# Port
PORT=4000
